# AWS backend environment variables
# Put these in your AWS service environment settings, or copy to Backend/.env on the server.

# Use your AWS RDS PostgreSQL URL in production.
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_RDS_ENDPOINT:5432/ai_call_db

# Frontend URL allowed by CORS.
# Examples:
# BACKEND_CORS_ORIGINS=https://your-app.amplifyapp.com
# BACKEND_CORS_ORIGINS=https://your-cloudfront-domain.cloudfront.net
BACKEND_CORS_ORIGINS=https://YOUR_FRONTEND_AWS_URL

# Vapi settings
VAPI_BASE_URL=https://api.vapi.ai/call
VAPI_API_KEY=YOUR_VAPI_API_KEY
VAPI_ASSISTANT_ID=YOUR_VAPI_ASSISTANT_ID
VAPI_PHONE_NUMBER_ID=YOUR_VAPI_PHONE_NUMBER_ID

# Public backend webhook URL for Vapi.
# Example: https://your-api-domain.com/api/vapi-webhook
VAPI_SERVER_URL=https://YOUR_BACKEND_AWS_URL/api/vapi-webhook
VAPI_SERVER_MESSAGES=end-of-call-report,transcript

# Optional, only if you use OpenAI elsewhere in the backend.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
