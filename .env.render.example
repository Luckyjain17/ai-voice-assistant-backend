# Render backend environment variables
# Add these in Render Dashboard > Backend Web Service > Environment.

DATABASE_URL=YOUR_RENDER_POSTGRES_EXTERNAL_OR_INTERNAL_DATABASE_URL

# Your deployed frontend URL from Render.
BACKEND_CORS_ORIGINS=https://your-frontend-service.onrender.com

VAPI_BASE_URL=https://api.vapi.ai/call
VAPI_API_KEY=YOUR_VAPI_API_KEY
VAPI_ASSISTANT_ID=YOUR_VAPI_ASSISTANT_ID
VAPI_PHONE_NUMBER_ID=YOUR_VAPI_PHONE_NUMBER_ID

# Your deployed backend URL from Render + /api/vapi-webhook
VAPI_SERVER_URL=https://your-backend-service.onrender.com/api/vapi-webhook
VAPI_SERVER_MESSAGES=end-of-call-report,transcript

OPENAI_API_KEY=YOUR_OPENAI_API_KEY
